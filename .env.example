PORT=5000
NODE_ENV=development

# Local: mongodb://127.0.0.1:27017/chaufeer
# Atlas:  mongodb+srv://username:password@cluster.mongodb.net/chaufeer
MONGODB_URI=mongodb://127.0.0.1:27017/chaufeer

# Frontend URLs allowed to call this API (comma-separated)
CLIENT_URL=http://localhost:3000,http://localhost:5173,https://chauffeur-brown.vercel.app

JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
OTP_EXPIRES_MINUTES=10

GOOGLE_CLIENT_ID=your_google_web_client_id
GOOGLE_CLIENT_ID_IOS=your_google_ios_client_id
GOOGLE_CLIENT_ID_ANDROID=your_google_android_client_id

FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Email - Option A: Gmail (free)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password
# EMAIL_FROM=Chaufeer <your@gmail.com>

# Email - Option B: Brevo (free - 300 emails/day)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_brevo_login_email@example.com
SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM=Chaufeer <your_verified_sender@example.com>

# Fatora Payment Gateway
# Sandbox public key (for testing): E4B73FEE-F492-4607-A38D-852B0EBC91C9
# Or use your own key from Fatora dashboard -> Integration
FATORA_API_KEY=E4B73FEE-F492-4607-A38D-852B0EBC91C9
FATORA_API_URL=https://api.fatora.io/v1
FATORA_CURRENCY=QAR

# Frontend URLs where Fatora redirects after payment
FATORA_SUCCESS_URL=https://chauffeur-brown.vercel.app/booking/payment/success
FATORA_FAILURE_URL=https://chauffeur-brown.vercel.app/booking/payment/failure

# Your deployed API URL (used when configuring Fatora webhook on Vercel)
API_BASE_URL=https://chaufeer.vercel.app
